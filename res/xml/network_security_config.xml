<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

    <!--
        GitHub API and release asset CDN domains.
        Assets redirect from api.github.com → *.githubusercontent.com or *.amazonaws.com (S3).
    -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.github.com</domain>
        <domain includeSubdomains="true">github.com</domain>
        <domain includeSubdomains="true">objects.githubusercontent.com</domain>
        <domain includeSubdomains="true">releases.githubusercontent.com</domain>
        <domain includeSubdomains="true">codeload.github.com</domain>
        <domain includeSubdomains="true">amazonaws.com</domain>
        <domain includeSubdomains="true">s3.amazonaws.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- Fallback for all other domains (allows HTTP for misc traffic) -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

</network-security-config>
