<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ===== Full Black Theme ===== -->
    <style name="Theme.Nabra" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/nabra_primary</item>
        <item name="colorPrimaryVariant">@color/nabra_primary_variant</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/nabra_secondary</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="android:windowBackground">@color/black</item>
        <item name="android:colorBackground">@color/black</item>
        <item name="colorSurface">@color/black</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorOnBackground">@color/white</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/gray_light</item>

        <item name="materialButtonStyle">@style/Widget.Nabra.Button</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.Nabra.Button.Outlined</item>
        <item name="borderlessButtonStyle">@style/Widget.Nabra.Button.Text</item>
        <item name="popupMenuStyle">@style/Widget.Nabra.PopupMenu</item>

        <!-- AlertDialog background → black with blue border -->
        <item name="alertDialogStyle">@style/Theme.Nabra.Dialog</item>
        <item name="android:alertDialogTheme">@style/Theme.Nabra.Dialog</item>
    </style>

    <!-- ===== Alert Dialog: black background + blue border ===== -->
    <style name="Theme.Nabra.Dialog" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="android:windowBackground">@drawable/bg_dialog_black</item>
        <item name="colorSurface">@color/black</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/gray_light</item>
        <item name="colorPrimary">@color/nabra_primary</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.Nabra.Button</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.Nabra.Button.Text</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.Nabra.Button.Text</item>
    </style>

    <!-- Filled button: black bg + purple border + white text -->
    <style name="Widget.Nabra.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/black</item>
        <item name="strokeColor">@color/nabra_primary</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="iconTint">@color/white</item>
        <item name="rippleColor">@color/nabra_primary</item>
    </style>

    <!-- Outlined button: black bg + purple border + purple text -->
    <style name="Widget.Nabra.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="backgroundTint">@color/black</item>
        <item name="strokeColor">@color/nabra_primary</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/nabra_primary</item>
        <item name="iconTint">@color/nabra_primary</item>
        <item name="rippleColor">@color/nabra_primary</item>
    </style>

    <!-- Text button: no bg + purple text -->
    <style name="Widget.Nabra.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/nabra_primary</item>
        <item name="iconTint">@color/nabra_primary</item>
    </style>

    <!-- Popup overflow menu -->
    <style name="Widget.Nabra.PopupMenu" parent="Widget.AppCompat.PopupMenu">
        <item name="android:popupBackground">@color/dark_card</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Theme.Nabra.NoActionBar" parent="Theme.Nabra">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="Theme.Nabra.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />
    <style name="Theme.Nabra.PopupOverlay" parent="ThemeOverlay.AppCompat.Dark" />

</resources>
