<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/black"
        android:theme="@style/Theme.Nabra.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/black"
            android:contentDescription="@string/about"
            app:popupTheme="@style/Theme.Nabra.PopupOverlay"
            app:title="@string/about"
            app:titleTextColor="@color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- App icon -->
            <ImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_marginBottom="16dp"
                android:src="@mipmap/ic_launcher_round"
                android:contentDescription="@string/app_name"
                android:importantForAccessibility="yes" />

            <!-- App name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:importantForAccessibility="yes" />

            <!-- Divider -->
            <View
                android:layout_width="60dp"
                android:layout_height="2dp"
                android:background="@color/nabra_primary"
                android:layout_marginBottom="20dp"
                android:importantForAccessibility="no" />

            <!-- Description -->
            <TextView
                android:id="@+id/tv_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/about_description"
                android:textColor="@color/gray_light"
                android:textSize="16sp"
                android:lineSpacingMultiplier="1.5"
                android:gravity="center"
                android:layout_marginBottom="32dp"
                android:importantForAccessibility="yes" />

            <!-- YouTube button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_youtube"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:text="@string/btn_youtube"
                android:contentDescription="@string/btn_youtube_desc"
                android:textSize="15sp"
                app:icon="@android:drawable/ic_menu_share"
                app:iconGravity="textEnd" />

            <!-- Telegram button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_telegram"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:text="@string/btn_telegram"
                android:contentDescription="@string/btn_telegram_desc"
                android:textSize="15sp"
                app:icon="@android:drawable/ic_menu_send"
                app:iconGravity="textEnd" />

            <!-- Email / Contact button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_email"
                style="@style/Widget.Nabra.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp"
                android:text="@string/btn_email"
                android:contentDescription="@string/btn_email_desc"
                android:textSize="15sp"
                app:icon="@android:drawable/ic_dialog_email"
                app:iconGravity="textEnd" />

        </LinearLayout>

    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
