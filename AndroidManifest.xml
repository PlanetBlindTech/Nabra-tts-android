<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.pbt.nabratts">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Necessary for package visibility on Android 11+ -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <queries>
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
        <intent>
            <action android:name="android.speech.tts.engine.CHECK_TTS_DATA" />
        </intent>
        <intent>
            <action android:name="android.speech.tts.engine.GET_SAMPLE_TEXT" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Nabra"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Nabra.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".SettingsActivity"
            android:label="@string/settings"
            android:exported="false"
            android:theme="@style/Theme.Nabra.NoActionBar" />

        <activity
            android:name=".AboutActivity"
            android:label="@string/about"
            android:exported="false"
            android:theme="@style/Theme.Nabra.NoActionBar" />

        <activity
            android:name=".DictionaryActivity"
            android:label="@string/dictionary"
            android:exported="false"
            android:theme="@style/Theme.Nabra.NoActionBar" />

        <!-- Corrected permission and added exported -->
        <service
            android:name=".NativeTtsService"
            android:label="@string/tts_service_label"
            android:permission="android.permission.BIND_TEXT_TO_SPEECH_ENGINE"
            android:exported="true">
            <intent-filter android:priority="100">
                <action android:name="android.intent.action.TTS_SERVICE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <meta-data
                android:name="android.speech.tts"
                android:resource="@xml/tts_engine" />
        </service>

        <!-- Activities for TTS Engine Integration -->
        <activity
            android:name=".CheckVoiceData"
            android:theme="@android:style/Theme.NoDisplay"
            android:label="@string/app_name"
            android:exported="true">
            <intent-filter>
                <action android:name="android.speech.tts.engine.CHECK_TTS_DATA" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".GetSampleText"
            android:theme="@android:style/Theme.NoDisplay"
            android:label="@string/app_name"
            android:exported="true">
            <intent-filter>
                <action android:name="android.speech.tts.engine.GET_SAMPLE_TEXT" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

    </application>

</manifest>
